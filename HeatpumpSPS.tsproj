	<DataTypes>
		<DataType>
			<Name GUID="{A467AA11-2982-4501-1CAC-3C4ABFA7905B}" AutoDeleteType="true">ST_ConfigValues</Name>
			<BitSize>288</BitSize>
			<SubItem>
				<Name>targetTemperatureOn</Name>
				<Type GUID="{18071995-0000-0000-0000-00000000000D}">REAL</Type>
				<Comment><![CDATA[ Einschalttemperatur bei deren Unterschreiten die Waermepumpe eingeschaltet wird]]></Comment>
				<BitSize>32</BitSize>
				<BitOffs>0</BitOffs>
				<Default>
					<Value>38</Value>
				</Default>
			</SubItem>
			<SubItem>
				<Name>targetTemperatureOff</Name>
				<Type GUID="{18071995-0000-0000-0000-00000000000D}">REAL</Type>
				<Comment><![CDATA[ Einschalttemperatur bei deren Ueberschreiten die Waermepume ausgeschaltet wird]]></Comment>
				<BitSize>32</BitSize>
				<BitOffs>32</BitOffs>
				<Default>
					<Value>38</Value>
				</Default>
			</SubItem>
			<SubItem>
				<Name>minIdleSec</Name>
				<Type GUID="{18071995-0000-0000-0000-000000000048}">TIME</Type>
				<Comment><![CDATA[	:= 	30; 	// Minimale Auschalt-Dauer (verhindert haeufiges Einschalten) [Sekunden]]]></Comment>
				<BitSize>32</BitSize>
				<BitOffs>64</BitOffs>
				<Default>
					<DateTime>T#5S</DateTime>
				</Default>
			</SubItem>
			<SubItem>
				<Name>lowPressureIgnoreTimeSec</Name>
				<Type GUID="{18071995-0000-0000-0000-000000000006}">INT</Type>
				<Comment><![CDATA[ Nach dem Einschalten sollen Niederdruck-Warnungen für eine gewisse Zeit ignoriert werden]]></Comment>
				<BitSize>16</BitSize>
				<BitOffs>96</BitOffs>
				<Default>
					<Value>20</Value>
				</Default>
			</SubItem>
			<SubItem>
				<Name>temperatureDiffBacklashOff</Name>
				<Type GUID="{18071995-0000-0000-0000-00000000000D}">REAL</Type>
				<Comment><![CDATA[ Temperaturdifferenz zwischen Vorlauf und Rücklauf, bei dessen Unterschreiten die Wasserpumpe ausgeschaltet wird]]></Comment>
				<BitSize>32</BitSize>
				<BitOffs>128</BitOffs>
				<Default>
					<Value>1</Value>
				</Default>
			</SubItem>
			<SubItem>
				<Name>pressureHighMax</Name>
				<Type GUID="{18071995-0000-0000-0000-00000000000D}">REAL</Type>
				<Comment><![CDATA[ Maximaler Druck auf der Hochdruckseite [bar]]]></Comment>
				<BitSize>32</BitSize>
				<BitOffs>160</BitOffs>
				<Default>
					<Value>16</Value>
				</Default>
			</SubItem>
			<SubItem>
				<Name>pressureLowMax</Name>
				<Type GUID="{18071995-0000-0000-0000-00000000000D}">REAL</Type>
				<Comment><![CDATA[ Maximaler Druck auf der Niederdruckseite [bar]]]></Comment>
				<BitSize>32</BitSize>
				<BitOffs>192</BitOffs>
				<Default>
					<Value>6</Value>
				</Default>
			</SubItem>
			<SubItem>
				<Name>pressureDifferenceEvaporatorMax</Name>
				<Type GUID="{18071995-0000-0000-0000-00000000000D}">REAL</Type>
				<Comment><![CDATA[  Maximaler Druckverlust des Verdampfer-Wärmetauschers [mbar]]]></Comment>
				<BitSize>32</BitSize>
				<BitOffs>224</BitOffs>
				<Default>
					<Value>100</Value>
				</Default>
			</SubItem>
			<SubItem>
				<Name>evaporatingTemperatureOutMin</Name>
				<Type GUID="{18071995-0000-0000-0000-00000000000D}">REAL</Type>
				<Comment><![CDATA[ Minimale Temperatur am Austritt des Verdampfer-Wärmetausschers. Triplepunkt des Wassers. [�C]]]></Comment>
				<BitSize>32</BitSize>
				<BitOffs>256</BitOffs>
				<Default>
					<Value>3</Value>
				</Default>
			</SubItem>
