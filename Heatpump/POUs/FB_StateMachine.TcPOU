    </Property>
    <Method Name="setButtonState" Id="{a15529d2-7ea5-42a9-a30a-580f1f9b30bd}">
      <Declaration><![CDATA[METHOD setButtonState : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF iState.State <> E_State.OFF THEN 
	isStopButtonEnabled := TRUE;
	isStartButtonEnabled := FALSE;
ELSE 
	isStopButtonEnabled := FALSE;
	isStartButtonEnabled := TRUE;
END_IF

bStartButtonPressed			:= FALSE;
bStopButtonPressed			:= FALSE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetState" Id="{d1b82ae6-b5f8-46df-b7d5-05a5b5812d18}">
      <Declaration><![CDATA[METHOD INTERNAL SetState : BOOL
VAR_INPUT
	newState : I_State;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.iState := newState;]]></ST>
      </Implementation>
    </Method>
