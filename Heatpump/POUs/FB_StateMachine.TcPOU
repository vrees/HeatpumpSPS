      </Get>
    </Property>
    <Property Name="RunningState" Id="{322a2666-716a-4153-b44f-a7d765f3afaa}">
      <Declaration><![CDATA[PROPERTY INTERNAL RunningState : I_State]]></Declaration>
      <Get Name="Get" Id="{5d6244d8-f12b-4996-a525-c240608b1a9f}">
