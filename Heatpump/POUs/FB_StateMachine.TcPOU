<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_StateMachine" Id="{c349ad72-d78c-44d0-9319-bf272785d3c6}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_StateMachine
VAR_INPUT	
	bOnButtonPressed			: 	BOOL;
	bOffButtonPressed			: 	BOOL;
END_VAR
VAR_IN_OUT
	pd 							: 	ST_ProcessData;
	configValues				:   ST_ConfigValues;
END_VAR
VAR_OUTPUT
	iState						:	I_State := fbOffState;	
	events						:	ST_Events;
END_VAR
VAR
	fbOffState					:	FB_OffState(THIS);
	fbIdleState					:	FB_IdleState(THIS);
	fbRunningState				:	FB_RunningState(THIS);
	fbCoolDownState				:	FB_CoolDownState(THIS);
	fbErrorState				:	FB_ErrorState(THIS);
		
	rtrigButtonSwitchOn			:	R_TRIG;
	rtrigButtonSwitchOff		:	R_TRIG;
	rtrigButtonConfirmation		:	R_TRIG;	

	isTaregetTemeraturReached: INT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[rtrigButtonSwitchOn(CLK := bOnButtonPressed);
rtrigButtonSwitchOff(CLK := bOffButtonPressed);
rtrigButtonConfirmation(CLK := pd.sensor.userConfirmation);

generateEvents();

IF events.switchOff.isTriggered THEN
	iState.UserPressedSwitchOffButton();
END_IF 

IF events.switchOn.isTriggered THEN
	iState.UserPressedSwitchOnButton();
END_IF 

IF events.confirmed.isTriggered THEN
	iState.UserPressedConfirmationButton();
END_IF 

IF events.heatIsRequested.isTriggered THEN
	iState.HeatIsRequested();
END_IF 

IF events.targetTemperatureReached.isTriggered THEN
	iState.TargetTemeperatureReached();
END_IF 

IF events.cooledDown.isTriggered THEN
	iState.WaterHasCooledDown();
END_IF

]]></ST>
    </Implementation>
    <Property Name="CoolDownState" Id="{f97b0a89-973c-4c1a-a93f-bd53afa029ed}">
      <Declaration><![CDATA[PROPERTY INTERNAL CoolDownState : I_State]]></Declaration>
      <Get Name="Get" Id="{b6372e95-c683-40ad-a452-2ce707a937ae}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[CoolDownState := THIS^.fbCoolDownState;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="ErrorState" Id="{82bf1b50-5572-411a-a70d-536ddc4cc417}">
      <Declaration><![CDATA[PROPERTY INTERNAL ErrorState : I_State]]></Declaration>
      <Get Name="Get" Id="{b38f7974-de10-4e45-820b-f02c66d60dde}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[ErrorState := THIS^.fbErrorState;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="FB_init" Id="{6d3466aa-93d5-49ab-ba3a-3a7a40038459}">
      <Declaration><![CDATA[//FB_Init ist immer implizit verfügbar und wird primär für die Initialisierung verwendet.
//Der Rückgabewert wird nicht ausgewertet. Für gezielte Einflussnahme können Sie
//die Methoden explizit deklarieren und darin mit dem Standard-Initialisierungscode 
//zusätzlichen Code bereitstellen. Sie können den Rückgabewert auswerten.
METHOD FB_Init: BOOL
VAR_INPUT    
	bInitRetains: BOOL; // TRUE: Die Retain-Variablen werden initialisiert (Reset warm / Reset kalt)    
	bInCopyCode: BOOL;  // TRUE: Die Instanz wird danach in den Kopiercode kopiert (Online-Change)
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="generateEvents" Id="{83685a53-198e-44e2-9f24-60ab8684b413}">
      <Declaration><![CDATA[METHOD generateEvents : BOOL

VAR
	isTriggered: BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF (rtrigButtonSwitchOff.Q OR (rtrigButtonConfirmation.Q AND iState.State <> E_State.OFF)) THEN
	events.switchOff.isTriggered := TRUE;
END_IF

IF (rtrigButtonSwitchOn.Q OR (rtrigButtonConfirmation.Q AND iState.State = E_State.OFF)) THEN
	events.switchOn.isTriggered := TRUE;
END_IF

IF (rtrigButtonConfirmation.Q) THEN
	events.switchOn.isTriggered := TRUE;
END_IF

IF (pd.sensor.bufferTopTemperature < configValues.targetTemperatureOn) THEN
	events.heatIsRequested.isTriggered := TRUE;
END_IF

IF ((pd.sensor.temperatureFlow - pd.sensor.temperatureReturn) < configValues.temperatureDiffBacklashOff) THEN
	events.cooledDown.isTriggered := TRUE;
END_IF

IF (pd.sensor.temperatureFlow > configValues.targetTemperatureOff) THEN
	events.targetTemperatureReached.isTriggered := TRUE;
END_IF


]]></ST>
      </Implementation>
    </Method>
