<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_StateMachine" Id="{c349ad72-d78c-44d0-9319-bf272785d3c6}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_StateMachine
VAR_INPUT	
	pd 							: 	REFERENCE TO ST_ProcessData;
END_VAR
VAR_OUTPUT
	iState						:	I_State := fbOffState;	
	events						:	ST_Events();
	defaultEvents 				: 	ST_Events();  			// leere Kopie
END_VAR
VAR
	fbOffState					:	FB_OffState(THIS);
	fbIdleState					:	FB_IdleState(THIS);
	fbRunningState				:	FB_RunningState(THIS);
	fbCoolDownState				:	FB_CoolDownState(THIS);
	fbErrorState				:	FB_ErrorState(THIS);
	timerTON 					: 	TON;             		// TON-Timer
	
	bStartButtonPressed    		: 	BOOL;
	bStopButtonPressed			: 	BOOL;		
	rtrigButtonSwitchOn			:	R_TRIG;
	rtrigButtonSwitchOff		:	R_TRIG;
	rtrigButtonConfirmation		:	R_TRIG;	
	strState					: 	STRING;
	
	isStartButtonEnabled		:	BOOL 	:=	TRUE;
	isStopButtonEnabled			:	BOOL 	:=	TRUE;
	timerValueToDisplay			:	INT		:= 	0;	
	bIsTimerVisible				: 	BOOL	:=  FALSE;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[rtrigButtonSwitchOn(CLK := bStartButtonPressed);
rtrigButtonSwitchOff(CLK := bStopButtonPressed);
rtrigButtonConfirmation(CLK := pd.sensor.userConfirmation);
timerTON();

// Zuweisung von defaultEvent zu myEvent (Wertkopie)
events := defaultEvents;

generateEvents(events);

IF events.errorsDetected THEN
	iState.ErrorDetected(events.errorEvents);
END_IF 

IF events.switchOff.isTriggered THEN
	iState.UserPressedSwitchOffButton();
END_IF 

IF events.switchOn.isTriggered THEN
	iState.UserPressedSwitchOnButton();
END_IF 

IF events.confirmed.isTriggered THEN
	iState.UserPressedConfirmationButton();
END_IF 

IF events.heatIsRequested.isTriggered THEN
	iState.HeatIsRequested();
END_IF 

IF events.targetTemperatureReached.isTriggered THEN
	iState.TargetTemeperatureReached();
END_IF 

IF events.cooledDown.isTriggered THEN
	iState.WaterHasCooledDown();
END_IF

strState := iState.Name;

setButtonState();

timerTON();
timerValueToDisplay := convertTimerToDisplayValue(timerTON);

IF iState.State = E_State.IDLE AND timerTON.IN = TRUE AND timerTON.Q = FALSE THEN 	
	bIsTimerVisible := TRUE;
ELSE
	bIsTimerVisible := FALSE;
END_IF]]></ST>
    </Implementation>
    <Property Name="CoolDownState" Id="{f97b0a89-973c-4c1a-a93f-bd53afa029ed}">
      <Declaration><![CDATA[PROPERTY INTERNAL CoolDownState : I_State]]></Declaration>
      <Get Name="Get" Id="{b6372e95-c683-40ad-a452-2ce707a937ae}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[CoolDownState := THIS^.fbCoolDownState;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="ErrorState" Id="{82bf1b50-5572-411a-a70d-536ddc4cc417}">
      <Declaration><![CDATA[PROPERTY INTERNAL ErrorState : I_State]]></Declaration>
      <Get Name="Get" Id="{b38f7974-de10-4e45-820b-f02c66d60dde}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[ErrorState := THIS^.fbErrorState;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="FB_init" Id="{6d3466aa-93d5-49ab-ba3a-3a7a40038459}">
      <Declaration><![CDATA[//FB_Init ist immer implizit verfügbar und wird primär für die Initialisierung verwendet.
//Der Rückgabewert wird nicht ausgewertet. Für gezielte Einflussnahme können Sie
//die Methoden explizit deklarieren und darin mit dem Standard-Initialisierungscode 
//zusätzlichen Code bereitstellen. Sie können den Rückgabewert auswerten.
METHOD FB_Init: BOOL
VAR_INPUT    
	bInitRetains: BOOL; // TRUE: Die Retain-Variablen werden initialisiert (Reset warm / Reset kalt)    
	bInCopyCode: BOOL;  // TRUE: Die Instanz wird danach in den Kopiercode kopiert (Online-Change)
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="generateEvents" Id="{83685a53-198e-44e2-9f24-60ab8684b413}">
      <Declaration><![CDATA[METHOD generateEvents : BOOL
VAR_IN_OUT
	events					:	ST_Events();
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF (rtrigButtonSwitchOff.Q OR (rtrigButtonConfirmation.Q AND (iState.State <> E_State.OFF OR iState.State = E_State.ERROR))) THEN
	events.switchOff.isTriggered := TRUE;
ELSIF (rtrigButtonSwitchOn.Q OR (rtrigButtonConfirmation.Q AND iState.State = E_State.OFF)) THEN
	events.switchOn.isTriggered := TRUE;
ELSIF (pd.sensor.bufferTopTemperature < GVL.configValues.targetTemperatureOn AND iState.State = E_State.IDLE) THEN
	events.heatIsRequested.isTriggered := TRUE;
ELSIF ((pd.sensor.temperatureFlow - pd.sensor.temperatureReturn) < GVL.configValues.temperatureDiffBacklashOff AND iState.State = E_State.COOLDOWN) THEN
	events.cooledDown.isTriggered := TRUE;
ELSIF (pd.sensor.bufferTopTemperature > GVL.configValues.targetTemperatureOff AND iState.State = E_State.RUNNING) THEN
	events.targetTemperatureReached.isTriggered := TRUE;
END_IF


//***** Errors *****

(* Prüfe maximalen Druck auf der Niederdruckseite über Ranco Thermostat [bar] *)
IF pd.incident.incidentLowPressure THEN
	events.errorEvents.LowPressureRefrigerationThermostat.message := CONCAT('Ranco Thermostat: zu hoher Niederdruck [bar]: ', ScaleAndRoundString(pd.sensor.pressureLow, 10));
	events.errorEvents.LowPressureRefrigerationThermostat.isTriggered := TRUE;
	events.errorsDetected := TRUE;
END_IF

(*Prüfe maximalen Druck auf der Hochdruckseite über Ranco Thermostat [bar]  *)
IF pd.incident.incidentHighPressure THEN
	events.errorEvents.HighPressureRefrigerationThermostat.message := CONCAT('Ranco Thermostat: zu hoher Hochdruck [bar]: ', ScaleAndRoundString(pd.sensor.pressureHigh, 10));
	events.errorEvents.HighPressureRefrigerationThermostat.isTriggered := TRUE;
	events.errorsDetected := TRUE;
END_IF

(* Motor-Schutzschalter hat ausgelöst *)
IF pd.incident.incidentCompressor THEN
	events.errorEvents.MotorProtectionTriggered.message := 'Motorschutzschalter hat ausgelöst';
	events.errorEvents.MotorProtectionTriggered.isTriggered := TRUE;
	events.errorsDetected := TRUE;
END_IF

(* Expansionsventil meldet Fehler *)
IF pd.incident.alarmExpansionValve THEN
	events.errorEvents.ExpansionValveTriggered.message := 'Expansionsventil meldet Fehler';
	events.errorEvents.ExpansionValveTriggered.isTriggered := TRUE;
	events.errorsDetected := TRUE;
END_IF

(* Maximaler Druckverlust des Verdampfer-Wärmetauschers [mbar] *)
IF pd.sensor.PressureDifferenceEvaporator > GVL.configValues.PressureDifferenceEvaporatorMax THEN
	events.errorEvents.PressureDiffEvaporatorTooHigh.message := CONCAT('Druckdifferenz [mbar]: ', REAL_TO_STRING(REAL_TO_INT(pd.sensor.PressureDifferenceEvaporator)));
	events.errorEvents.PressureDiffEvaporatorTooHigh.isTriggered := TRUE;
	events.errorsDetected := TRUE;
END_IF

(* Prüfe minimale Temperatur am Austritt des Verdampfer-Wärmetausschers. Triplepunkt des Wassers. [°C] *)
IF pd.sensor.TemperatureEvaporatingOut < GVL.configValues.EvaporatingTemperatureOutMin THEN
	events.errorEvents.EvaporatingTemperatureTooLow.message := CONCAT('Austritttemperatur am Verdampfer ist zu niedrig [°C]: ', ScaleAndRoundString(pd.sensor.TemperatureEvaporatingOut, 10));
	events.errorEvents.EvaporatingTemperatureTooLow.isTriggered := TRUE;
	events.errorsDetected := TRUE;
END_IF

(* Prüfe, of Wasser Durchflussmenge ausreichend ist. Mindestens 2500 Liter/Stunde *)
IF pd.incident.incidentFlow THEN
	events.errorEvents.EvaporatingFlowRateTooLow.message := 'Quellwasser Durchflussmenge zu niedrig';
	events.errorEvents.EvaporatingFlowRateTooLow.isTriggered := TRUE;
	events.errorsDetected := TRUE;
END_IF

// ***** Warnings *****

(* Prüfe maximalen Druck auf der Niederdruckseite [bar] *)
IF pd.sensor.PressureLow > GVL.configValues.PressureLowMax THEN
	events.warningEvents.LowPressureRefrigerationCalc.message := CONCAT('Niederdruck: [bar]: ', ScaleAndRoundString(pd.sensor.PressureLow, 10));
	events.warningEvents.LowPressureRefrigerationCalc.isTriggered := TRUE;
ELSE
	events.warningEvents.LowPressureRefrigerationCalc.isTriggered := FALSE;
END_IF

(* Prüfe maximalen Druck auf der Hochdruckseite [bar] *)
IF pd.sensor.PressureHigh > GVL.configValues.PressureHighMax THEN
	events.warningEvents.HighPressureRefrigerationCalc.message := CONCAT('', ScaleAndRoundString(pd.sensor.PressureHigh, 10));
	events.warningEvents.HighPressureRefrigerationCalc.isTriggered := TRUE;
ELSE
	events.warningEvents.HighPressureRefrigerationCalc.isTriggered := FALSE;
END_IF

(* TANK_LEVEL_TOO_LOW *)
IF FALSE THEN
	events.warningEvents.WaterTankLevelTooLow.message := 'Wasserstand der Quelle ist zu meiedrig';
	events.warningEvents.WaterTankLevelTooLow.isTriggered := TRUE;
END_IF

(* TANK_LEVEL Data missing *)
IF FALSE THEN
	events.warningEvents.WaterTankDataMissing.message := 'Keine Daten über den Wasserstand der Quelle verfügbar';
	events.warningEvents.WaterTankDataMissing.isTriggered := TRUE;
END_IF


]]></ST>
      </Implementation>
    </Method>
    <Property Name="IdleState" Id="{909b78a6-5091-4b36-9866-235bb070dd8d}">
      <Declaration><![CDATA[PROPERTY INTERNAL IdleState : I_State]]></Declaration>
