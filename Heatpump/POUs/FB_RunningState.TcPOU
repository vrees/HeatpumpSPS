    <Property Name="State" Id="{75386ad7-2492-4d3c-8098-8f6c395c0bbb}">
      <Declaration><![CDATA[PROPERTY State : E_State]]></Declaration>
      <Get Name="Get" Id="{81495c4a-f76d-4331-90b6-4378394cf226}">
