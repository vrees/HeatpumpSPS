<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_RunningState" Id="{db7d51fb-2638-4812-b81a-d21aedf1ed00}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_RunningState IMPLEMENTS I_State
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	pMachine : POINTER TO FB_StateMachine;	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="ActionSwitchOff" Id="{46ba5a55-86e3-4497-8746-3df853385ea5}">
      <Declaration><![CDATA[METHOD ActionSwitchOff : BOOL
VAR_INPUT
	message		:	STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[ADSLOGSTR(ADSLOG_MSGTYPE_HINT, message, pMachine^.iState.Description);
pMachine^.timerTON(IN := TRUE, PT := GVL.configValues.minIdleSec);
pMachine^.SetState(pMachine^.CoolDownState);






]]></ST>
      </Implementation>
    </Method>
    <Property Name="Description" Id="{fff56124-f3e0-4a4a-810d-d034fa66ff15}">
      <Declaration><![CDATA[{warning 'Eigenschaftenimplementierung hinzufügen'}
PROPERTY Description : STRING
]]></Declaration>
      <Get Name="Get" Id="{09f84e37-527b-4c45-880e-5502fab1a5a1}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[Description := 'Heat pump is running';]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="ErrorDetected" Id="{2d6db66f-da00-40a1-96dd-ed61a3c7e83c}">
      <Declaration><![CDATA[METHOD ErrorDetected : BOOL
VAR_INPUT
	errorEvents		: ST_ErrorEvents;
END_VAR
VAR
	message				: STRING(255);
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[message := toErrorText(errorEvents);
ADSLOGSTR(ADSLOG_MSGTYPE_HINT, 'Error detected', message);
pMachine^.SetState(pMachine^.ErrorState);]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{ccdf553b-48e7-41c3-825a-9b44d85c7b93}">
      <Declaration><![CDATA[//FB_Init ist immer implizit verfügbar und wird primär für die Initialisierung verwendet.
//Der Rückgabewert wird nicht ausgewertet. Für gezielte Einflussnahme können Sie
//die Methoden explizit deklarieren und darin mit dem Standard-Initialisierungscode 
//zusätzlichen Code bereitstellen. Sie können den Rückgabewert auswerten.
METHOD FB_Init: BOOL
VAR_INPUT    
	bInitRetains: BOOL; // TRUE: Die Retain-Variablen werden initialisiert (Reset warm / Reset kalt)    
	bInCopyCode: BOOL;  // TRUE: Die Instanz wird danach in den Kopiercode kopiert (Online-Change)
	pMachine : POINTER TO FB_StateMachine;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.pMachine := pMachine;]]></ST>
      </Implementation>
    </Method>
