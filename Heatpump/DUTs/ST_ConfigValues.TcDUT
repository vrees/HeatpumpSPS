<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <DUT Name="ST_ConfigValues" Id="{019656bf-067e-4483-97b4-def6d34d2ddb}">
    <Declaration><![CDATA[TYPE ST_ConfigValues :
STRUCT	
	targetTemperatureOn 			:	REAL	:= 	38; 	// Einschalttemperatur bei deren Unterschreiten die Waermepumpe eingeschaltet wird
	targetTemperatureOff 			:	REAL	:= 	38; 	// Auschaltemperatur bei deren Ueberschreiten die Waermepume ausgeschaltet wird
	minIdleSec 						:	TIME 	:= 	T#10S;	//	:= 	30; 	// Minimale Auschalt-Dauer (verhindert haeufiges Einschalten) [Sekunden]
	lowPressureIgnoreTime 			:	TIME 	:= 	T#20S;	// Nach dem Einschalten sollen Niederdruck-Warnungen für eine gewisse Zeit ignoriert werden
	temperatureDiffBacklashOff 		:	REAL	:= 	1.0; 	// Temperaturdifferenz zwischen Vorlauf und Rücklauf, bei dessen Unterschreiten die Wasserpumpe ausgeschaltet wird

	// Limits*)
	pressureHighMax 				:	REAL	:= 	16; 	// Maximaler Druck auf der Hochdruckseite [bar]
	pressureLowMax 					:	REAL	:= 	6; 		// Maximaler Druck auf der Niederdruckseite [bar]
	pressureDifferenceEvaporatorMax :	REAL 	:= 	100;	//  Maximaler Druckverlust des Verdampfer-Wärmetauschers [mbar]
	evaporatingTemperatureOutMin 	:	REAL 	:=	3; 		// Minimale Temperatur am Austritt des Verdampfer-Wärmetausschers. Triplepunkt des Wassers. [�C]
END_STRUCT
END_TYPE
]]></Declaration>
  </DUT>
</TcPlcObject>